# Application
NODE_ENV=production

# API Configuration
API_PORT=3333

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=best_lap
DB_PASSWORD=best_lap
DB_NAME=best_lap_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Bull Board Dashboard
BULL_BOARD_PORT=4000

# Google API (optional)
GOOGLE_API_KEY=your_google_api_key_here

# Metrics Collection (Brazil timezone: America/Sao_Paulo)
# Default: 8AM, 2PM, 8PM Brazilian time
COLLECT_METRICS_CRON_EXPRESSION=0 8,14,20 * * *
WORKER_CONCURRENCY=10
SEED_THEMES_URL=https://lucsmac.github.io/autodromo-domains/full_data.json