{
  "name": "best-lap",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "admin": "turbo run dev --filter=@best-lap/admin",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "infra:up": "docker-compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker-compose -f docker-compose.infra.yml down",
    "infra:logs": "docker-compose -f docker-compose.infra.yml logs -f",
    "start": "concurrently \"pnpm --filter=@best-lap/api start\" \"pnpm --filter=@best-lap/admin start\" \"pnpm --filter=@best-lap/metrics-collector start\"",
    "start:prod": "pnpm build && pnpm infra:up && pnpm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.14.0"
}