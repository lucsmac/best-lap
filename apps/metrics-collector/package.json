{
  "name": "@best-lap/metrics-collector",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm env:load ts-node --transpile-only src/index.ts",
    "collect": "pnpm env:load ts-node --transpile-only src/collect.ts",
    "env:load": "dotenv -e ../../.env --",
    "build": "tsup src/index.ts --format cjs --target node18 --out-dir dist --external dotenv --external dotenv/config",
    "start": "pnpm env:load node dist/index.js",
    "start:prod": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@best-lap/env": "workspace:*",
    "@best-lap/eslint-config": "workspace:*",
    "@best-lap/prettier": "workspace:*",
    "@best-lap/tsconfig": "workspace:*",
    "@types/node": "^24.0.13",
    "dotenv-cli": "^8.0.0"
  },
  "eslintConfig": {
    "extends": [
      "@best-lap/eslint-config/library"
    ]
  },
  "prettier": "@best-lap/prettier",
  "dependencies": {
    "@best-lap/core": "workspace:*",
    "@best-lap/infra": "workspace:*",
    "dotenv": "^16.4.5",
    "node-cron": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0"
  }
}